{
  "version": 2,
  "builds": [
    {
      "src": "web-backend/api.py",
      "use": "@vercel/python"
    },
    {
      "src": "web-frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "web-backend/api.py"
    },
    {
      "src": "/(.*)",
      "dest": "web-frontend/$1"
    }
  ]
}